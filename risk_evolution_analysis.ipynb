"""
Example workflow for analysing evolving risk patterns
in environmental and operational systems.
"""
import numpy as np
import matplotlib.pyplot as plt

time = np.arange(0, 100)

risk = (
    0.2*np.sin(time/5)
    + 0.03*time
    + np.random.normal(0, 0.1, len(time))
)

plt.figure(figsize=(10,4))
plt.plot(time, risk)
plt.xlabel("Time")
plt.ylabel("Risk Indicator")
plt.title("Temporal Evolution of Risk")
plt.show()

gradient = np.gradient(risk)

plt.figure(figsize=(10,4))
plt.plot(time, gradient)
plt.axhline(0, linestyle='--')
plt.title("Risk Transition Indicator")
plt.show()
